  "terminal": {
    "background": "#0d1117",
    "foreground": "#e6edf3",
    "cursor": "#2f81f7",
    "selectionBackground": "#3e404380",
    "ansi": {
      "black": "#484f58",
      "red": "#ff7b72",
      "green": "#3fb950",
      "yellow": "#d29922",
      "blue": "#58a6ff",
      "magenta": "#bc8cff",
      "cyan": "#39c5cf",
      "white": "#b1bac4"
    },
    "ansiBright": {
      "black": "#6e7681",
      "red": "#ffa198",
      "green": "#56d364",
      "yellow": "#e3b341",
      "blue": "#79c0ff",
      "magenta": "#d2a8ff",
      "cyan": "#56d4dd",
      "white": "#ffffff"
    }
