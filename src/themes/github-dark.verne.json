  "syntax": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "color": "#8b949e"
    },
    {
      "scope": [
        "constant.other.placeholder",
        "constant.character"
      ],
      "color": "#ff7b72"
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.other.constant",
        "variable.other.enummember",
        "variable.language",
        "entity"
      ],
      "color": "#79c0ff"
    },
    {
      "scope": [
        "entity.name",
        "meta.export.default",
        "meta.definition.variable"
      ],
      "color": "#ffa657"
    },
    {
      "scope": [
        "variable.parameter.function",
        "meta.jsx.children",
        "meta.block",
        "meta.tag.attributes",
        "entity.name.constant",
        "meta.object.member",
        "meta.embedded.expression"
      ],
      "color": "#e6edf3"
    },
    {
      "scope": "entity.name.function",
      "color": "#d2a8ff"
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "color": "#7ee787"
    },
    {
      "scope": "keyword",
      "color": "#ff7b72"
    },
    {
      "scope": [
        "storage",
        "storage.type"
      ],
      "color": "#ff7b72"
    },
    {
      "scope": [
        "storage.modifier.package",
        "storage.modifier.import",
        "storage.type.java"
      ],
      "color": "#e6edf3"
    },
    {
      "scope": [
        "string",
        "string punctuation.section.embedded source"
      ],
      "color": "#a5d6ff"
    },
    {
      "scope": "support",
      "color": "#79c0ff"
    },
    {
      "scope": "meta.property-name",
      "color": "#79c0ff"
    },
    {
      "scope": "variable",
      "color": "#ffa657"
    },
    {
      "scope": "variable.other",
      "color": "#e6edf3"
    },
    {
      "scope": "invalid.broken",
      "color": "#ffa198",
      "italic": true
    },
    {
      "scope": "invalid.deprecated",
      "color": "#ffa198",
      "italic": true
    },
    {
      "scope": "invalid.illegal",
      "color": "#ffa198",
      "italic": true
    },
    {
      "scope": "invalid.unimplemented",
      "color": "#ffa198",
      "italic": true
    },
    {
      "scope": "carriage-return",
      "color": "#f0f6fc",
      "bg": "#ff7b72",
      "italic": true,
      "underline": true
    },
    {
      "scope": "message.error",
      "color": "#ffa198"
    },
    {
      "scope": "string variable",
      "color": "#79c0ff"
    },
    {
      "scope": [
        "source.regexp",
        "string.regexp"
      ],
      "color": "#a5d6ff"
    },
    {
      "scope": [
        "string.regexp.character-class",
        "string.regexp constant.character.escape",
        "string.regexp source.ruby.embedded",
        "string.regexp string.regexp.arbitrary-repitition"
      ],
      "color": "#a5d6ff"
    },
    {
      "scope": "string.regexp constant.character.escape",
      "color": "#7ee787",
      "bold": true
    },
    {
      "scope": "support.constant",
      "color": "#79c0ff"
    },
    {
      "scope": "support.variable",
      "color": "#79c0ff"
    },
    {
      "scope": "support.type.property-name.json",
      "color": "#7ee787"
    },
    {
      "scope": "meta.module-reference",
      "color": "#79c0ff"
    },
    {
      "scope": "punctuation.definition.list.begin.markdown",
      "color": "#ffa657"
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "color": "#79c0ff",
      "bold": true
    },
    {
      "scope": "markup.quote",
      "color": "#7ee787"
    },
    {
      "scope": "markup.italic",
      "color": "#e6edf3",
      "italic": true
    },
    {
      "scope": "markup.bold",
      "color": "#e6edf3",
      "bold": true
    },
    {
      "scope": [
        "markup.underline"
      ],
      "underline": true
    },
    {
      "scope": [
        "markup.strikethrough"
      ],
      "strikethrough": true
    },
    {
      "scope": "markup.inline.raw",
      "color": "#79c0ff"
    },
    {
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file",
        "punctuation.definition.deleted"
      ],
      "color": "#ffa198",
      "bg": "#490202"
    },
    {
      "scope": [
        "punctuation.section.embedded"
      ],
      "color": "#ff7b72"
    },
    {
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file",
        "punctuation.definition.inserted"
      ],
      "color": "#7ee787",
      "bg": "#04260f"
    },
    {
      "scope": [
        "markup.changed",
        "punctuation.definition.changed"
      ],
      "color": "#ffa657",
      "bg": "#5a1e02"
    },
    {
      "scope": [
        "markup.ignored",
        "markup.untracked"
      ],
      "color": "#161b22",
      "bg": "#79c0ff"
    },
    {
      "scope": "meta.diff.range",
      "color": "#d2a8ff",
      "bold": true
    },
    {
      "scope": "meta.diff.header",
      "color": "#79c0ff"
    },
    {
      "scope": "meta.separator",
      "color": "#79c0ff",
      "bold": true
    },
    {
      "scope": "meta.output",
      "color": "#79c0ff"
    },
    {
      "scope": [
        "brackethighlighter.tag",
        "brackethighlighter.curly",
        "brackethighlighter.round",
        "brackethighlighter.square",
        "brackethighlighter.angle",
        "brackethighlighter.quote"
      ],
      "color": "#8b949e"
    },
    {
      "scope": "brackethighlighter.unmatched",
      "color": "#ffa198"
    },
    {
      "scope": [
        "constant.other.reference.link",
        "string.other.link"
      ],
      "color": "#a5d6ff"
    }
  ]
}
