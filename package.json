{
  "name": "verne",
  "version": "0.1.3",
  "type": "module",
  "main": "out/main/index.cjs",
  "scripts": {
    "bundle:install": "pnpm --dir resources/bundled install",
    "postinstall": "node node_modules/electron/install.js && node scripts/sign-dev-electron.mjs",
    "daemon:build:dev": "cargo build --manifest-path daemon/Cargo.toml",
    "daemon:build": "cargo build --release --manifest-path daemon/Cargo.toml",
    "predev": "pnpm daemon:build:dev && pnpm bundle:install",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "prepackage": "pnpm daemon:build && pnpm bundle:install",
    "package": "electron-vite build && electron-builder",
    "package:unsigned": "pnpm prepackage && electron-vite build && electron-builder -c.mac.identity=null",
    "release": "pnpm prepackage && electron-vite build && electron-builder --publish always",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:renderer": "playwright test -c tests/renderer/playwright.config.ts",
    "test:rust": "cargo test --manifest-path daemon/Cargo.toml",
    "clippy": "cargo clippy --manifest-path daemon/Cargo.toml --all-targets",
    "fmt:check": "cargo fmt --manifest-path daemon/Cargo.toml --all -- --check"
  },
  "dependencies": {
    "@dnd-kit/abstract": "^0.3.2",
    "@dnd-kit/collision": "^0.3.2",
    "@dnd-kit/vue": "^0.3.2",
    "@internationalized/date": "^3.12.2",
    "@lucide/vue": "^1.17.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pierre/diffs": "^1.2.8",
    "@pierre/trees": "1.0.0-beta.4",
    "@tanstack/vue-virtual": "^3.13.28",
    "@unovis/vue": "^1.6.5",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": ">=3.4.0",
    "electron-updater": "^6.8.9",
    "embla-carousel-vue": "^8.6.0",
    "emmet-monaco-es": "^5.7.0",
    "markdown-it": "^14.2.0",
    "monaco-editor": "^0.55.1",
    "pidusage": "^4.0.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.9",
    "sherpa-onnx": "1.12.37",
    "shiki": "^3.23.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vscode-languageserver-protocol": "^3.18.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2",
    "vue": "^3.5.35",
    "vue-input-otp": "^0.3.2",
    "vue-sonner": "^2.0.9",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.20",
    "@types/pidusage": "^2.0.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "electron-builder-squirrel-windows": "26.8.1",
    "electron-vite": "^5.0.0",
    "esbuild": "0.28.0",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2.12"
  },
  "pnpm": {
    "overrides": {
      "dompurify": ">=3.4.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "electron-vite>vite": "8"
      }
    }
  },
  "optionalDependencies": {
    "sherpa-onnx-darwin-arm64": "1.12.37",
    "sherpa-onnx-darwin-x64": "1.12.37",
    "sherpa-onnx-linux-arm64": "1.12.37",
    "sherpa-onnx-linux-x64": "1.12.37",
    "sherpa-onnx-win-x64": "1.12.37"
  }
}
