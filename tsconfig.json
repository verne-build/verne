{
  "compilerOptions": {
    "target": "ESNext", "module": "ESNext", "moduleResolution": "Bundler",
    "strict": true, "jsx": "preserve", "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": ".", "paths": { "@/*": ["src/*"] }, "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "electron/preload/**/*.ts"]
}
